{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SavedOutput": {
      "title": "Saved Output",
      "description": "A saved recruitment output (JD and Interview Guide)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "rawNotes": { "type": "string" },
        "selectedLanguages": { "type": "array", "items": { "type": "string" } },
        "results": { 
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "jobDescription": { "type": "string" },
              "interviewGuide": { "type": "string" }
            }
          }
        },
        "isPublic": { "type": "boolean" },
        "isTemplate": { "type": "boolean" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "results", "createdAt"]
    },
    "Template": {
      "title": "Template",
      "description": "A reusable recruitment template shared with the community",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "rawNotes": { "type": "string" },
        "category": { "type": "string" },
        "installCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "rawNotes", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/saved_outputs/{outputId}": {
      "schema": "SavedOutput",
      "description": "Saved recruitment outputs"
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Publicly shared templates"
    }
  }
}
